    "license": "schema:license",
    "keywords": "schema:keywords",
    "email": "schema:email",
    "address": "schema:address",
    "repository": {
      "@id": "polimi:repository",
      "@type": "schema:DataCatalog"
    },
    "oaiBaseURL": {
      "@id": "polimi:oaiBaseURL",
